# REQUIRED: Clerk Authentication
# This is your Clerk publishable key (safe to expose client-side). 
# Find it in the Clerk dashboard under API Keys.
# Required -- the app throws an error at boot if unset.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# OPTIONAL: Backend API URL
# Leave unset for local dev (defaults to same-origin + vite.config.ts's proxy to localhost:8000). 
# Set explicitly for a deployed build pointing at a separately-hosted backend.
VITE_API_BASE=
