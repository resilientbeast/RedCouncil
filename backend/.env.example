# REQUIRED: Qwen API credentials
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# REQUIRED: Clerk Authentication
# This is your Clerk Frontend API URL. Find it in the Clerk dashboard under API Keys
# (e.g., https://your-app.clerk.accounts.dev). Used to verify the incoming JWTs.
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# OPTIONAL: System Hardening / HITL Gate
# Set to 'true' to pause execution after conflicts are detected for human review.
ENABLE_HITL_GATE=true

# OPTIONAL: Credit-protection rate limits
# These gate real Qwen API spend, so keep them small for a public demo.
MAX_DECISIONS_PER_USER_PER_DAY=5
MAX_TOTAL_DECISIONS_PER_DAY=30
# Comma-separated Clerk user_ids that bypass both caps above -- put your own
# account here so testing doesn't eat the budget you're protecting.
UNLIMITED_USER_IDS=user_2zX...

# OPTIONAL: Database Persistence
# Leave empty to use the in-memory store. 
# Set this to enable PostgresStore (Alibaba Cloud RDS or local docker-compose):
DATABASE_URL=sqlite+aiosqlite:///./redcouncil.db

# OPTIONAL: Alibaba Cloud OSS (persistent document blob storage)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
OSS_BUCKET_NAME=

# OPTIONAL: Slack Integration
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# Core Council configurations
MAX_DECISION_TEXT_LENGTH=2000
AGENT_TEMPERATURE=0.5
CORS_ALLOWED_ORIGINS=http://localhost:5173
